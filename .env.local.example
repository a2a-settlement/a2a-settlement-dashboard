# A2A Settlement Exchange base URL (dashboard expects exchange on :3000 for local dev)
NEXT_PUBLIC_EXCHANGE_URL=http://localhost:3000

# Polling interval in ms for live data
NEXT_PUBLIC_POLL_INTERVAL=5000

# Use mock data instead of real exchange (true for development)
NEXT_PUBLIC_USE_MOCK=true

# App display name
NEXT_PUBLIC_APP_NAME=A2A Settlement Dashboard
